<p>Tahun Pengalaman</p>
</div>

<div class="glass stat">
<h3>100+</h3>
<p>Proyek Sistem</p>
</div>

<div class="glass stat">
<h3>50+</h3>
<p>Pelatihan</p>
</div>

<div class="glass stat">
<h3>24/7</h3>
<p>Dedikasi Pelayanan</p>
</div>

</div>

